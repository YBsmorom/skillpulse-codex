{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SkillPulse",
  "version": "0.1.0",
  "identifier": "dev.skillpulse.codex",
  "build": {
    "beforeDevCommand": "vite --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "dock",
        "title": "SkillPulse Dock",
        "width": 16,
        "height": 16,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "focus": false,
        "focusable": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true
      },
      {
        "label": "panel",
        "title": "SkillPulse",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 620,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "focusable": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico"
    ],
    "targets": "all"
  }
}
